# ── Frontend (Vite, baked at build time) ──────────────────────────────────────
# API base path. In the Vercel deployment the API lives in the same project.
VITE_API_ENDPOINT=/api
# Clerk publishable key (intentionally public).
VITE_CLERK_PUBLISHABLE_KEY=

# ── API (Vercel Python function) ──────────────────────────────────────────────
# Neon Postgres — provisioned via the Vercel Marketplace integration.
DATABASE_URL=
# Clerk JWT verification.
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=
CLERK_SECRET_KEY=
# Comma-separated allowed browser origins (also used for azp checks).
FRONTEND_ORIGINS=
# GitHub Actions worker dispatch.
GH_REPO=owner/repo
GH_DISPATCH_TOKEN=

# ── Blob uploads (api/upload.js) ──────────────────────────────────────────────
# Provisioned automatically when the Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=

# ── Worker (GitHub Actions secret, not Vercel) ────────────────────────────────
# The workflow reads DATABASE_URL from repo secrets.
